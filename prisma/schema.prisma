generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Warehouse {
  id            String   @id @default(uuid())
  name          String
  location      String
  address       String?
  contactPerson String?
  phone         String?
  capacity      Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stock            Stock[]
  stockMovements   StockMovement[]
  orders           Order[]
  purchaseOrders   PurchaseOrder[]
  batches          Batch[]
  serialNumbers    SerialNumber[]
  employees        Employee[]
}

model Material {
  id              String    @id @default(uuid())
  sku             String    @unique
  name            String
  category        String
  unit            String
  unitPrice       Decimal   @db.Decimal(12, 2)
  reorderLevel    Int       @default(0)
  reorderQuantity Int       @default(0)
  description     String?
  imageUrl        String?
  expiryDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stock            Stock[]
  stockMovements   StockMovement[]
  orderItems       OrderItem[]
  purchaseItems    PurchaseOrderItem[]
  variants         ProductVariant[]
  batches          Batch[]
  serialNumbers    SerialNumber[]
}

model Stock {
  id          String  @id @default(uuid())
  warehouseId String
  materialId  String
  quantity    Decimal @db.Decimal(12, 2)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  material  Material  @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warehouseId, materialId])
}

model Wholesaler {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxId         String?
  creditLimit   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders         Order[]
  purchaseOrders PurchaseOrder[]
}

model Order {
  id           String   @id @default(uuid())
  orderNumber  String   @unique
  warehouseId  String
  wholesalerId String
  status       String   @default("PENDING")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  warehouse  Warehouse   @relation(fields: [warehouseId], references: [id])
  wholesaler Wholesaler  @relation(fields: [wholesalerId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  materialId String
  quantity   Decimal @db.Decimal(12, 2)
  unitPrice  Decimal @db.Decimal(12, 2)

  order    Order    @relation(fields: [orderId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
}

model StockMovement {
  id          String   @id @default(uuid())
  warehouseId String
  materialId  String
  type        String
  quantity    Decimal  @db.Decimal(12, 2)
  referenceId String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  material  Material  @relation(fields: [materialId], references: [id])
}

model ShipmentMethod {
  id            String   @id @default(uuid())
  name          String
  carrierName   String?
  baseCost      Decimal  @db.Decimal(12, 2)
  estimatedDays Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]
}

model Batch {
  id               String    @id @default(uuid())
  batchNumber      String    @unique
  materialId       String
  warehouseId      String
  quantity         Decimal   @db.Decimal(12, 2)
  manufacturingDate DateTime?
  expiryDate       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  material  Material  @relation(fields: [materialId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  serialNumbers SerialNumber[]
}

model SerialNumber {
  id          String   @id @default(uuid())
  serialNumber String  @unique
  materialId  String
  warehouseId String
  batchId     String?
  status      String   @default("AVAILABLE")
  orderId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  material  Material  @relation(fields: [materialId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  batch     Batch?    @relation(fields: [batchId], references: [id])
}

model ProductVariant {
  id          String  @id @default(uuid())
  materialId  String
  name        String
  sku         String  @unique
  attributes  Json?
  unitPrice   Decimal @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id])
}

model PurchaseOrder {
  id            String   @id @default(uuid())
  poNumber      String   @unique
  warehouseId   String
  wholesalerId  String
  status        String   @default("PENDING")
  expectedDate  DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  warehouse  Warehouse           @relation(fields: [warehouseId], references: [id])
  wholesaler Wholesaler          @relation(fields: [wholesalerId], references: [id])
  items      PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  materialId      String
  quantity        Decimal @db.Decimal(12, 2)
  unitPrice       Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  material      Material      @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Employee {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String?
  position    String
  department  String?
  warehouseId String?
  hireDate    DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  workLogs  WorkLog[]
}

model WorkLog {
  id          String   @id @default(uuid())
  employeeId  String
  date        DateTime @default(now())
  startTime   DateTime
  endTime     DateTime?
  hoursWorked Float
  taskType    String
  description String
  quantity    Float?
  unit        String?
  status      String   @default("COMPLETED")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}
